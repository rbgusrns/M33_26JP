{
  "configurations": [
    {
      "name": "STM32H533",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "USE_HAL_DRIVER",
        "USE_FULL_LL_DRIVER",
        "STM32H533xx",
        "DEBUG"
      ],
      "compilerPath": "${env:STM32CubeCLT_ROOT}/GNU-tools-for-STM32/bin/arm-none-eabi-gcc.exe",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "gcc-arm",
      "compileCommands": "${workspaceFolder}/build/Debug/compile_commands.json"
    }
  ],
  "version": 4
}
